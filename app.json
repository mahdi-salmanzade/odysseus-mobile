{
  "expo": {
    "name": "Odysseus",
    "slug": "odysseus-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "odysseusmobile",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/images/icon.png",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "tech.mindzone.odysseus",
      "icon": {
        "light": "./assets/images/icon.png",
        "dark": "./assets/images/icon-dark.png",
        "tinted": "./assets/images/icon-tinted.png"
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "Odysseus connects to your self-hosted Odysseus server on your local network so you can chat with it.",
        "NSCameraUsageDescription": "Odysseus uses the camera to scan the pairing QR code shown by your Odysseus server.",
        "NSPhotoLibraryUsageDescription": "Odysseus can read a saved image from your photo library so you can scan a pairing QR code you've stored.",
        "NSPhotoLibraryAddUsageDescription": "Odysseus can save a pairing QR code image to your photo library.",
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "package": "tech.mindzone.odysseus",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "monochromeImage": "./assets/images/icon-tinted.png",
        "backgroundColor": "#16161a"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.INTERNET"
      ]
    },
    "web": {
      "output": "static",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#e06c75"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Odysseus uses the camera to scan the pairing QR code shown by your Odysseus server.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Odysseus uses the microphone to turn your speech into a message you can send.",
          "speechRecognitionPermission": "Odysseus uses on-device speech recognition to transcribe what you say into the message box."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "expo-speech-recognition"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "279b5893-2348-486a-b7d1-df419a5eb3d9"
      }
    },
    "owner": "mahdibordo",
    "updates": {
      "url": "https://u.expo.dev/279b5893-2348-486a-b7d1-df419a5eb3d9"
    }
  }
}
