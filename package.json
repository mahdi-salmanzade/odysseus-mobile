{
  "name": "odysseus-mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "description": "Native mobile remote for Odysseus, the self-hosted AI workspace. Pair over LAN and chat from your phone.",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "test:ci": "jest --ci --coverage"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "<rootDir>/__tests__/**/*-test.[jt]s?(x)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "collectCoverageFrom": [
      "src/lib/**/*.{ts,tsx}",
      "!src/lib/**/*.d.ts"
    ]
  },
  "dependencies": {
    "expo": "~56.0.3",
    "expo-build-properties": "~56.0.16",
    "expo-camera": "~56.0.7",
    "expo-clipboard": "~56.0.3",
    "expo-constants": "~56.0.16",
    "expo-device": "~56.0.4",
    "expo-haptics": "~56.0.3",
    "expo-linking": "~56.0.13",
    "expo-network": "~56.0.4",
    "expo-notifications": "~56.0.15",
    "expo-router": "~56.2.5",
    "expo-secure-store": "~56.0.4",
    "expo-speech-recognition": "^56.0.0",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.17",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-marked": "^8.1.0",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@testing-library/react-native": "^14.0.0",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.2",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~56.0.4",
    "jest": "~29.7.0",
    "jest-expo": "~56.0.4",
    "typescript": "~6.0.3"
  },
  "private": true
}
